{
  "name": "meteorvoice",
  "version": "1.3.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm --workspace @meteorvoice/web run dev",
    "build": "npm --workspace @meteorvoice/web run build",
    "start": "npm --workspace @meteorvoice/web run start",
    "lint": "eslint",
    "web:dev": "npm --workspace @meteorvoice/web run dev",
    "web:lint": "npm --workspace @meteorvoice/web run lint",
    "web:build": "npm --workspace @meteorvoice/web run build",
    "web:start": "npm --workspace @meteorvoice/web run start",
    "mobile:start": "npm --workspace @meteorvoice/mobile run start",
    "mobile:ios": "npm --workspace @meteorvoice/mobile run ios",
    "mobile:android": "npm --workspace @meteorvoice/mobile run android",
    "mobile:config": "npm --workspace @meteorvoice/mobile exec expo config -- --type public",
    "mobile:typecheck": "npm --workspace @meteorvoice/mobile run typecheck",
    "packages:test": "vitest run tests/api-client.test.ts tests/session-core.test.ts",
    "test": "vitest run && npm run web:build",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "test:e2e": "npm test && npm run e2e"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.35",
    "@langchain/core": "^1.1.46",
    "@langchain/langgraph": "^1.3.5",
    "@meteorvoice/api-client": "file:packages/api-client",
    "@meteorvoice/session-core": "file:packages/session-core",
    "@meteorvoice/shared": "file:packages/shared",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.0",
    "ai": "^6.0.185",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo-router": "~55.0.16",
    "lucide-react": "^1.16.0",
    "next": "^16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "^16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
