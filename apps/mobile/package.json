    "expo-modules-core": "~55.0.25",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.15",
    "expo-speech-recognition": "^56.0.0",
    "expo-status-bar": "~55.0.6",
    "react": "19.2.0",
    "react-native": "0.83.6",
