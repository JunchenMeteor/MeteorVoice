# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI Model (optional - app works in mock mode without this)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional: Production STT/TTS providers
# STT_PROVIDER=mock|browser|whisper
# TTS_PROVIDER=mock|xunfei|volcengine|tencent

# Xunfei TTS (recommended first provider in China)
XUNFEI_APP_ID=
XUNFEI_API_KEY=
XUNFEI_API_SECRET=
# Required when TTS_PROVIDER=xunfei. Use a V3-compatible vcn from the Xunfei console.
XUNFEI_TTS_VOICE=
# Trial examples only; do not leave enabled after 2026-06-09 00:00 Asia/Shanghai:
# XUNFEI_TTS_VOICE=x4_enus_catherine_profnews         # English male
# XUNFEI_TTS_VOICE_AMERICAN=x4_enus_ryan_assist      # English female
# Optional accent-specific overrides. These must also be V3-compatible vcn values.
XUNFEI_TTS_VOICE_AMERICAN=
XUNFEI_TTS_VOICE_BRITISH=
XUNFEI_TTS_VOICE_INDIAN=

# Volcengine TTS
VOLCENGINE_TTS_APP_ID=
VOLCENGINE_TTS_ACCESS_TOKEN=
VOLCENGINE_TTS_CLUSTER=volcano_tts
VOLCENGINE_TTS_VOICE=BV001_streaming

# Tencent Cloud TTS
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_TTS_REGION=ap-guangzhou
TENCENT_TTS_VOICE=101001
